# ============================================
# CONFIGURACIÓN DE BASE DE DATOS
# ============================================
# Copia este archivo como .env y ajusta los valores

DB_HOST=127.0.0.1
DB_USER=tu_usuario
DB_PASSWORD=tu_password
DB_NAME=aprendizaje_inventario

# ============================================
# CONFIGURACIÓN DEL SERVIDOR
# ============================================

PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ============================================
# CONFIGURACIÓN JWT
# ============================================
# Genera un secreto seguro con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

JWT_SECRET=genera_un_secreto_seguro_de_64_caracteres
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ============================================
# CONFIGURACIÓN EMAIL (Gmail con App Password)
# ============================================
# Para Gmail: Habilita verificación en 2 pasos y genera una "Contraseña de aplicación"
# https://myaccount.google.com/apppasswords

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_contraseña_de_aplicacion
SMTP_FROM=Sistema Carpas <tu_correo@gmail.com>

      "type": "text",
      "id": "pQr0G",
      "x": 40.000015258789176,
      "y": -508,
      "name": "For best results select Claude Sonnet 4.5 as a model",
      "fill": "fff",
      "content": "FYI: When you run the prompt, you will have to allow the MCP calls.",

# ============================================
# Docker Compose - Variables de Entorno
# ============================================
# Copia este archivo como .env en la raíz del proyecto:
#   cp .env.docker.example .env
#
# Docker Compose lee .env automáticamente.
# NUNCA subas .env a Git (ya está en .gitignore).

# ============================================
# BASE DE DATOS (MySQL)
# ============================================
DB_ROOT_PASSWORD=rootpassword
DB_NAME=aprendizaje_inventario
DB_USER=appuser
DB_PASSWORD=apppassword

# ============================================
# BACKEND (Node.js / Express)
# ============================================
JWT_SECRET=change_me_generate_a_64_char_hex_secret
NODE_ENV=development
FRONTEND_URL=http://localhost:4173

# ============================================
# FRONTEND (React / Vite) - variable de build
# ============================================
VITE_API_URL=http://localhost:3000/api

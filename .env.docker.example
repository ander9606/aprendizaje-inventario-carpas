# ============================================
# Docker Compose - Variables de Entorno
# ============================================
# Copia este archivo como .env en la raíz del proyecto:
#   cp .env.docker.example .env
#
# Docker Compose lee .env automáticamente.
# NUNCA subas .env a Git (ya está en .gitignore).

# ============================================
# BASE DE DATOS (MySQL)
# ============================================
DB_ROOT_PASSWORD=rootpassword
DB_NAME=aprendizaje_inventario
DB_USER=appuser
DB_PASSWORD=apppassword

# ============================================
# BACKEND (Node.js / Express)
# ============================================
# IMPORTANTE: Genera un secreto seguro para producción:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_generate_a_64_char_hex_secret
NODE_ENV=production
FRONTEND_URL=http://localhost

# ============================================
# PRODUCCIÓN - HTTPS (opcional)
# ============================================
# Solo necesario si usas ./scripts/deploy.sh --https
# Requiere un dominio apuntando a la IP del servidor
DOMAIN=tu-dominio.com
CERTBOT_EMAIL=tu@email.com
